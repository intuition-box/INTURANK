# =============================================================================
# PLACEHOLDERS ARE IN THIS FILE (.env.example) — NOT inside .env.local by default.
#
# .env.local is gitignored and is YOUR private file. It is not created by git clone.
# To get placeholders into .env.local, run from the project root:
#
#   cp .env.example .env.local
#
# Then open `.env.local` and replace every `your_*` / example value with real keys.
# After editing, restart `npm run dev` (Vite reads VITE_* only at startup).
# =============================================================================
#
# TEMPLATE ONLY — commit this file. Do NOT put real secrets here.
# GitHub Actions: add the same variable names under repo Settings → Secrets and Variables.
# For LOCAL DEV: leave VITE_GRAPHQL_URL unset so Vite proxies /v1/graphql (avoids CORS + rate limit)
# For PRODUCTION: set VITE_GRAPHQL_URL=https://mainnet.intuition.sh/v1/graphql
# VITE_GRAPHQL_URL=https://mainnet.intuition.sh/v1/graphql
VITE_MAINTENANCE_MODE=false
VITE_WEB3_STORAGE_TOKEN=your_web3_storage_token
# One key, or several separated by commas (random pick per request — spreads quota across keys)
VITE_GEMINI_API_KEY=your_gemini_api_key
# Optional: defaults to gemini-2.5-flash; override if you need a specific model ID for your key
# VITE_GEMINI_MODEL=
# Optional: OpenAI fallback (Skill chat when Gemini is rate-limited). Same comma trick as Gemini.
# VITE_OPENAI_API_KEY=sk-first,sk-second
# Optional: defaults to gpt-4o-mini
# VITE_OPENAI_MODEL=gpt-4o-mini
# Optional: Groq (OpenAI-compatible, fast) — used after Gemini fails, before OpenAI. https://console.groq.com
# VITE_GROQ_API_KEY=gsk_...
# Optional: defaults to llama-3.3-70b-versatile (see Groq model list)
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
# Required for WalletConnect / mobile & tablet wallets — create at https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=
# Optional: public origin of the deployed app (WalletConnect metadata / deep links). Defaults to window.location.origin.
# VITE_APP_URL=https://your-domain.com
# Public base URL of the email API (Coolify, Railway, etc.) — no trailing slash
VITE_EMAIL_API_URL=https://email-api.yourdomain.com
ENSEND_PROJECT_SECRET=your_ensend_secret
ENSEND_SENDER_EMAIL=your-sender@ensend.me
ENSEND_SENDER_NAME=IntuRank
NFT_STORAGE_TOKEN=your_nft_storage_token
PORT=3001
ENABLE_EMAIL_WORKER=true
# Docker/Coolify: mount a volume here so subscriptions survive redeploys (do not mount over /app/server)
# EMAIL_DATA_DIR=/app/email-data

# Arena (`/climb`): omit or false = “coming soon” placeholder at /climb; true = full Arena UI. Nav always links to /climb.
# VITE_ARENA_ENABLED=true

# Arena: when stake > 0, each pick sends native TRUST to this address only (plain transfer — NOT a vault deposit / no market shares).
# Copy to .env.local and restart `npm run dev` after any VITE_* change (Vite reads env at startup).
# VITE_ARENA_TREASURY_ADDRESS=0xYourTreasuryWallet
# Default tier on load: Spark=0.1 … Singularity=10 (no free tier)
# VITE_ARENA_DEFAULT_STAKE_TRUST=0.1
# Optional: POST JSON { address, xp, duels, t } for global Arena XP sync
# VITE_ARENA_LEADERBOARD_URL=

# Optional: pin Season 2 default epoch id in UI (overrides date-based selection). Add new epochs in constants.ts.
# VITE_SEASON2_CURRENT_EPOCH_ID=10
