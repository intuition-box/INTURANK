# Copy to .env.production or .env.local - NEVER commit real values
# For LOCAL DEV: leave VITE_GRAPHQL_URL unset so Vite proxies /v1/graphql (avoids CORS + rate limit)
# For PRODUCTION: set VITE_GRAPHQL_URL=https://mainnet.intuition.sh/v1/graphql
# VITE_GRAPHQL_URL=https://mainnet.intuition.sh/v1/graphql
VITE_MAINTENANCE_MODE=false
VITE_WEB3_STORAGE_TOKEN=your_web3_storage_token
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_EMAIL_API_URL=https://your-email-api.up.railway.app
ENSEND_PROJECT_SECRET=your_ensend_secret
ENSEND_SENDER_EMAIL=your-sender@ensend.me
ENSEND_SENDER_NAME=IntuRank
NFT_STORAGE_TOKEN=your_nft_storage_token
PORT=3001
ENABLE_EMAIL_WORKER=true
